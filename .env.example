# 이 파일을 복사해서 .env 로 저장 후 값을 채우세요.
# cp .env.example .env

# ────────────────────────────────────────────────
# 공개 URL (https, 끝에 슬래시 없음)
# 단축 URL, QR 코드, 만료 리다이렉트에 모두 사용됩니다.
# nginx/conf.d/default.conf 의 server_name / ssl 경로와 반드시 일치해야 합니다.
# ────────────────────────────────────────────────
PUBLIC_URL=https://your-domain.com

# ── DB ──────────────────────────────────────────
DB_USERNAME=urluser
DB_PASSWORD=changeme

# ── Redis (비밀번호 없이 사용하려면 빈칸 유지) ──
REDIS_PASSWORD=

# ── JWT 서명 키 (Base64 인코딩, 32바이트 이상 권장) ──
# 생성: openssl rand -base64 32
JWT_SECRET=YOUR_VERY_LONG_BASE64_JWT_SECRET_HERE
